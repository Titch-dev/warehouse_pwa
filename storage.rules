rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function authRole() {
      return isSignedIn() && ("role" in request.auth.token)
        ? request.auth.token.role
        : null;
    }

    function isAdminOrOwner() {
      return isSignedIn() &&
        (authRole() == "admin" || authRole() == "owner");
    }

    function isImageUpload() {
      return request.resource != null &&
        request.resource.contentType.matches('image/.*');
    }

    function isReasonableSize() {
      return request.resource != null &&
        request.resource.size < 10 * 1024 * 1024;
    }

    match /uploads/raw/events/manual/{fileName} {
      allow write: if isAdminOrOwner() && isImageUpload() && isReasonableSize();
      allow read: if isAdminOrOwner();
    }

    match /events/manual/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    match /uploads/raw/events/facebook/{fileName} {
      allow read, write: if false;
    }

    match /events/facebook/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}