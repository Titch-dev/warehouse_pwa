rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return isSignedIn() ? userDoc().data.role : null;
    }

    function isAdmin() {
      return isSignedIn() && (
        userRole() == "admin" ||
        userRole() == "owner"
      );
    }

    // Public website assets
    match /gallery/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /events/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /menu/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /specials/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User profile photos if needed later
    match /users/{uid}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}