rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* ---------------- Helpers ---------------- */

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Secure source of truth for authorization:
    // custom claims set by Admin SDK / Cloud Functions
    function authRole() {
      return isSignedIn() && ("role" in request.auth.token)
        ? request.auth.token.role
        : null;
    }

    function isSuspended() {
      return isSignedIn() &&
        ("suspended" in request.auth.token) &&
        request.auth.token.suspended == true;
    }

    function isStaff() {
      return isSignedIn() &&
        !isSuspended() &&
        (
          authRole() == "staff" ||
          authRole() == "admin" ||
          authRole() == "owner"
        );
    }

    function isAdmin() {
      return isSignedIn() &&
        !isSuspended() &&
        (
          authRole() == "admin" ||
          authRole() == "owner"
        );
    }

    function isOwner() {
      return isSignedIn() &&
        !isSuspended() &&
        authRole() == "owner";
    }

    function isValidUserRole(role) {
      return role == "customer" ||
             role == "staff" ||
             role == "admin" ||
             role == "owner";
    }

    function isValidUserStatus(status) {
      return status == "active" ||
             status == "inactive" ||
             status == "suspended";
    }

    /* ---------------- Public website content ---------------- */

    match /metadata/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /events/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /menu/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /specials/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gallery/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /* ---------------- Users ---------------- */

    match /users/{uid} {
      // Self can read own doc.
      // Staff/admin/owner can read user docs for support / scanning / operations.
      allow read: if isSelf(uid) || isStaff();

      // Signup creation:
      // only self, cannot escalate role/status
      allow create: if isSelf(uid)
        && request.resource.data.uid == uid
        && request.resource.data.role == "customer"
        && request.resource.data.status == "active"
        && request.resource.data.keys().hasOnly([
          "uid",
          "email",
          "displayName",
          "photoURL",
          "role",
          "status",
          "membership",
          "createdAt",
          "updatedAt",
          "lastLoginAt"
        ]);

      // Self-update:
      // user may only edit a safe subset of fields
      // and may not change uid / role / status / membership
      allow update: if isSelf(uid)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status
        && request.resource.data.membership == resource.data.membership
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "displayName",
          "photoURL",
          "updatedAt",
          "lastLoginAt"
        ]);

      // No client-side privileged writes to sensitive user fields.
      // role / status / suspension mirrors should be updated by Cloud Functions only.
      allow delete: if false;
    }

    /* ---------------- Sessions ---------------- */

    match /sessions/{sessionId} {
      // Signed-in users can read unless you want suspended users blocked from all app access.
      allow read: if isSignedIn();

      // Backend / Cloud Functions only
      allow write: if false;
    }

    /* ---------------- Admin-only operational collections ---------------- */

    match /auditLogs/{docId} {
      // I recommend owner-only here since these are sensitive
      allow read: if isOwner();
      allow write: if false;
    }

    match /cms/{docId} {
      allow read, write: if isAdmin();
    }

    /* ---------------- Catch-all deny ---------------- */

    match /{document=**} {
      allow read, write: if false;
    }
  }
}