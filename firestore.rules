rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* ---------------- Helpers ---------------- */

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Secure source of truth for authorization:
    // custom claims set by Admin SDK / Cloud Functions
    function authRole() {
      return isSignedIn() && ("role" in request.auth.token)
        ? request.auth.token.role
        : null;
    }

    function isSuspended() {
      return isSignedIn() &&
        ("suspended" in request.auth.token) &&
        request.auth.token.suspended == true;
    }

    function isStaff() {
      return isSignedIn() &&
        !isSuspended() &&
        (
          authRole() == "staff" ||
          authRole() == "admin" ||
          authRole() == "owner"
        );
    }

    function isAdmin() {
      return isSignedIn() &&
        !isSuspended() &&
        (
          authRole() == "admin" ||
          authRole() == "owner"
        );
    }

    function isOwner() {
      return isSignedIn() &&
        !isSuspended() &&
        authRole() == "owner";
    }

    /* ---------------- Public website content ---------------- */

    match /metadata/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /events/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /menu/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /specials/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gallery/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /* ---------------- Users ---------------- */

    match /users/{uid} {
      // Self can read own doc.
      // Staff/admin/owner can read user docs for support / operations.
      allow read: if isSelf(uid) || isStaff();

      // New user doc creation at signup.
      allow create: if isSelf(uid)
        && request.resource.data.uid == uid
        && request.resource.data.role == "customer"
        && request.resource.data.status == "active"
        && request.resource.data.suspended == false
        && request.resource.data.keys().hasOnly([
          "uid",
          "email",
          "displayName",
          "photoURL",
          "role",
          "status",
          "suspended",
          "membership",
          "createdAt",
          "updatedAt",
          "lastLoginAt"
        ]);

      // Self may only update safe profile/login metadata fields.
      allow update: if isSelf(uid)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status
        && request.resource.data.suspended == resource.data.suspended
        && request.resource.data.membership == resource.data.membership
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "displayName",
          "photoURL",
          "updatedAt",
          "lastLoginAt"
        ]);

      allow delete: if false;
    }

    /* ---------------- Sessions ---------------- */

    match /sessions/{sessionId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    /* ---------------- Pool sessions ---------------- */

    match /pool_sessions/{uid} {
      function isOwnPoolSessionDoc() {
        return isSignedIn() && request.auth.uid == uid;
      }

      function hasValidPoolSessionShape() {
        return request.resource.data.keys().hasOnly([
          "userId",
          "status",
          "startedAt",
          "endedAt",
          "endReason",
          "membershipSnapshot",
          "checkInSource",
          "userSnapshot",
          "createdAt",
          "updatedAt"
        ]);
      }

      function keepsImmutablePoolSessionFields() {
        return request.resource.data.userId == resource.data.userId
          && request.resource.data.startedAt == resource.data.startedAt
          && request.resource.data.membershipSnapshot == resource.data.membershipSnapshot
          && request.resource.data.checkInSource == resource.data.checkInSource
          && request.resource.data.userSnapshot == resource.data.userSnapshot
          && request.resource.data.createdAt == resource.data.createdAt;
      }

      allow read: if isSignedIn() && !isSuspended() && (
        isOwnPoolSessionDoc() ||
        isStaff()
      );

      // Customer creates/replaces only their own current pool session doc as active.
      allow create: if isSignedIn()
        && !isSuspended()
        && isOwnPoolSessionDoc()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == "active"
        && request.resource.data.endedAt == null
        && request.resource.data.endReason == null
        && hasValidPoolSessionShape();

      // Customer may:
      // 1) overwrite their own doc into a fresh active session on check-in
      // 2) end their own currently active session
      allow update: if isSignedIn()
        && !isSuspended()
        && isOwnPoolSessionDoc()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && hasValidPoolSessionShape()
        && (
          // Re-check-in / overwrite current session doc as active
          (
            request.resource.data.status == "active"
            && request.resource.data.endedAt == null
            && request.resource.data.endReason == null
          )
          ||
          // Customer ends own active session, without changing immutable snapshot fields
          (
            resource.data.status == "active"
            && request.resource.data.status == "ended"
            && request.resource.data.endReason == "customer"
            && keepsImmutablePoolSessionFields()
          )
        );

      allow delete: if false;
    }

    /* ---------------- Membership history  ---------------- */

    match /membership_adjustments/{adjustmentId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isStaff()
      );
      allow write: if false;
    }

    /* ---------------- Admin-only operational collections ---------------- */

    match /auditLogs/{docId} {
      allow read: if isOwner();
      allow write: if false;
    }

    match /cms/{docId} {
      allow read, write: if isAdmin();
    }

    /* ---------------- Catch-all deny ---------------- */

    match /{document=**} {
      allow read, write: if false;
    }
  }
}